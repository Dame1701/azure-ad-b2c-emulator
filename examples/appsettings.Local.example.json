{
  // Mount this file at /app/appsettings.Local.json to override the baked-in sample config.
  // You only need the keys you want to change; everything else falls back to the defaults.
  //
  // NOTE: .NET config merges JSON arrays by INDEX, not by appending. Declare the COMPLETE
  // Apis / Clients / Users arrays you want - otherwise leftover sample entries can leak in.
  "Emulator": {
    "PublicBaseUrl": "http://localhost:8080",
    "Tenant": "yourtenant.onmicrosoft.com",
    "TenantId": "11111111-1111-1111-1111-111111111111",

    "Branding": {
      "ProductName": "Acme",
      "EmulatorTag": "Auth Emulator",
      "LogoPath": ""
    },

    // A requested delegated scope is matched to an API by AppIdUri prefix; the matched API's
    // Audience becomes the access token's `aud`, and the part after the prefix becomes the
    // short scope (e.g. "access_as_user"). Audience usually equals your API app's client id.
    "Apis": [
      {
        "Audience": "<your-api-client-id>",
        "AppIdUri": "https://yourtenant.onmicrosoft.com/api",
        "Scopes": [ "access_as_user" ]
      }
    ],

    // Confidential clients allowed to use the client_credentials (M2M) grant. A blank Secret
    // accepts any secret. The Scopes are emitted as the scope claim your back-end reads.
    "Clients": [
      {
        "ClientId": "<your-daemon-client-id>",
        "Secret": "",
        "Audience": "<your-api-client-id>",
        "Scopes": [ "system.access" ]
      }
    ],

    // Interactive accounts shown on the login screen's dropdown. ObjectId must match whatever
    // id your application keys users on (it is emitted as oid / sub / nameidentifier).
    "Users": [
      {
        "ObjectId": "22222222-2222-2222-2222-222222222222",
        "Email": "admin@acme.example",
        "DisplayName": "Acme Admin",
        "Label": "admin",
        "Group": "Administrators",
        // Extra claims emitted verbatim - reproduce B2C custom attributes here.
        "Claims": {
          "extension_IsAdmin": "true"
        }
      },
      {
        "ObjectId": "33333333-3333-3333-3333-333333333333",
        "Email": "user@acme.example",
        "DisplayName": "Acme User",
        "Group": "Users",
        "Claims": {}
      }
    ]
  }
}
